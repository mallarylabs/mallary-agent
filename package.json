    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "mallary",
    "cli",
    "social-media",
    "publishing",
    "automation"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsx": "^4.20.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
