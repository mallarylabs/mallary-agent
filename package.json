{
  "name": "@mallary/cli",
  "version": "0.1.6",
  "description": "Official Mallary.ai CLI for social media posting, analytics, uploads, and webhook management.",
  "homepage": "https://github.com/mallarylabs/mallary-agent#readme",
  "bugs": {
    "url": "https://github.com/mallarylabs/mallary-agent/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mallarylabs/mallary-agent"
  },
  "type": "module",
  "bin": {
    "mallary": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "llms.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
